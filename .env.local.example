# Supabase Configuration
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: For server-side operations (Settings → API → service_role key)
# NEVER commit a real service role key — it bypasses all RLS
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Admin user UUID (bypasses role check for /admin route)
ADMIN_UID=
NEXT_PUBLIC_ADMIN_UID=

# Push Notifications
# Generate VAPID keys with: node scripts/generate-vapid-keys.mjs
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@screenplaystudio.app

# Secret for authenticating push/email API calls from DB triggers
# Generate with: node -e "console.log(crypto.randomUUID())"
PUSH_API_SECRET=

# App URL (used by DB trigger for push delivery)
# Set to your deployed URL in production, e.g. https://screenplaystudio.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Zeptomail SMTP (transactional emails via Zoho)
ZEPTOMAIL_USER=emailapikey
ZEPTOMAIL_PASS=your_zeptomail_api_key
EMAIL_FROM=noreply@screenplaystudio.fun
EMAIL_FROM_NAME=Screenplay Studio

# PayPal (for creator billing)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Set to 'live' for production (defaults to 'sandbox')
PAYPAL_MODE=
# Required for PayPal webhook signature verification
PAYPAL_WEBHOOK_ID=

# Cron secret for Vercel cron jobs
CRON_SECRET=

 
# Media server secret for RTMP/WebSocket auth
MEDIA_SERVER_SECRET=

# Open-source kill switch
# This powers the emergency shutdown page at a secret UUID-based URL.
# Generate a UUID: node -e "console.log(crypto.randomUUID())"
# IMPORTANT: Also set this in your Vercel Dashboard → Settings → Environment Variables
# Without this set in production, the kill switch page will show "not configured".
KILLSWITCH_SECRET=
